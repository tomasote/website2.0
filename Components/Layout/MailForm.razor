@inject IStringLocalizer<Resources> localizer
@inject IResend Resend
@rendermode InteractiveServer

<form class="outerFormContainer" method="post" @onsubmit="Submit" @formname="starship-plain-form">
    <AntiforgeryToken />
    <div class="formContainer">
        <h1 class="sendEmailTitle">@localizer["SendMeEmail"]</h1>
        <p class=@($"errorMessage {GetErrorHiddenClass()}")>@ErrorString</p>
        <p class=@($"successMessage {GetSuccessHiddenClass()}")>@localizer["SuccessMessage"]</p>
        <label>
            <MudTextField Class="messageBox" @bind-Value="Model!.Name" Label=@(localizer["NameLabel"]) Variant="Variant.Outlined" ShrinkLabel="true"></MudTextField>
        </label>
        <label>
            <MudTextField Class="messageBox" @bind-Value="Model!.Email" Label=@(localizer["EmailLabel"]) Variant="Variant.Outlined" ShrinkLabel="true"></MudTextField>
        </label>
        <label>
            <MudTextField Class="messageBox" @bind-Value="Model!.Message" Label=@(localizer["MessageLabel"]) Sizing="InputSizing.Fixed" Lines="10" Variant="Variant.Outlined" ShrinkLabel="true"></MudTextField>
        </label>
    </div>
    <div>
        <button class="sendButton" type="submit">@localizer["Send"]</button>
    </div>
</form>

@code {
    [SupplyParameterFromForm]
    private MailModel? Model { get; set; }
    private string ErrorString = "";
    private bool messageSent = false;
    protected override void OnInitialized()
    {
        Model ??= new();
    } 

    async Task Submit()
    {
        if (Model == null) return;
        if (!Model.Validate()) return;
        var message = new EmailMessage();
        message.Subject = "Kontakt från hemsida";
        message.From = "Acme <onboarding@resend.dev>";
        message.To.Add("tomas@perezjarnil.se");
        message.ReplyTo = Model.Email!;
        message.HtmlBody = $"<h1>Namn: {Model.Name!}</h1><p>{Model.Message}</p>";
        var response = await Resend.EmailSendAsync(message);
        if (response.Success)
        {
            messageSent = true;
            Model.Name = "";
            Model.Email = "";
            Model.Message = "";
        }
        else
        {
            ErrorString = localizer["ErrorMessage"];
        }
        StateHasChanged();
    }

    private string GetErrorHiddenClass()
    {
        return string.IsNullOrEmpty(ErrorString) ? "hidden" : "";
    }
    private string GetSuccessHiddenClass()
    {
        return messageSent ? "" : "hidden";
    }
}
